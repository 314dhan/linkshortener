<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener | Reduced</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="split-layout">
        <!-- Minimal, bold typographic hero -->
        <div class="hero-section">
            <h1>
                <i>Utility</i>
                Shorten.<br>Share.<br>Measure.
            </h1>
            <p class="subtitle">An elegant tool to reduce URL complexity without sacrificing legibility.</p>
        </div>
    
        <div class="interactive-section">
            <form action="/shorten" method="POST" id="shortenForm">
                <div class="input-wrapper">
                    <label for="originalUrl">Target URL</label>
                    <input type="url" name="originalUrl" id="originalUrl" placeholder="https://example.com/very/long/path" required autocomplete="off">
                </div>
        
                <button type="submit" id="submitBtn">
                    Generate Link &rarr;
                </button>
            </form>
        
            <div class="short-url-container">
                <% if (locals.error) { %>
                    <div class="result-card error-result">
                        <p class="error-message">
                            Error: <%= error %>
                        </p>
                    </div>
                <% } %>
        
                <% if (locals.shortUrl) { %>
                    <div class="result-card success-result">
                        <div class="result-label">Link Generated</div>
                        <div class="short-url-link">
                            <a href="<%= shortUrl %>" class="short-url-text" target="_blank">
                                <%= shortUrl %>
                            </a>
                            <button class="copy-button" onclick="copyToClipboard('<%= shortUrl %>')">
                                Copy
                            </button>
                        </div>
                        <p class="success-message">
                            Ready for distribution.
                        </p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                const copyButton = document.querySelector('.copy-button');
                const originalContent = copyButton.innerHTML;
                copyButton.innerHTML = 'Copied!';
                copyButton.style.background = 'var(--accent-color)';
                copyButton.style.color = 'var(--text-primary)';
                copyButton.style.borderColor = 'var(--accent-color)';
                
                setTimeout(function() {
                    copyButton.innerHTML = originalContent;
                    copyButton.style.background = '';
                    copyButton.style.color = '';
                    copyButton.style.borderColor = '';
                }, 2000);
            }, function(err) {
                console.error('Could not copy text: ', err);
            });
        }
    </script>
</body>
</html>
